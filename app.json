{
  "expo": {
    "name": "GeoCheckr",
    "slug": "geocheckr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#282828"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.geocheckr.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#282828"
      },
      "package": "com.geocheckr.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCl3ogHqguF1QcwhyHdvJmUkbgx3bpKLJI"
        }
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "GeoCheckr \u2014 Geografie Party-Spiel",
      "shortName": "GeoCheckr",
      "description": "Finde den Ort! Ein Geografie-Party-Spiel f\u00fcr 2-8 Spieler.",
      "backgroundColor": "#1a1a2e",
      "themeColor": "#e94560",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-camera",
      "expo-asset",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow GeoCheckr to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow GeoCheckr to use speech recognition."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b47d3e21-7bed-4c8b-bd12-e805eb1380f8"
      }
    },
    "owner": "tboese"
  }
}